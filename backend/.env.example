# HM-stofan v0.2 backend
# local = notar data/*.json úr verkefninu
# apifootball = sækir gögn úr API-Football, ef þú setur API lykil
PROVIDER=local
API_FOOTBALL_KEY=
API_FOOTBALL_HOST=v3.football.api-sports.io
API_FOOTBALL_LEAGUE=1
API_FOOTBALL_SEASON=2026
ALLOWED_ORIGINS=https://hmusa.netlify.app,http://localhost:8000,http://127.0.0.1:8000
CACHE_SECONDS=300
